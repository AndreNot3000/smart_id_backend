# MongoDB Configuration (MongoDB Atlas)
# Prefer the mongodb+srv:// connection string from Atlas (Connect → Drivers)
MONGODB_URL=your_mongodb_connection_string_here
DB_NAME=campus_id_saas
# Local dev on Windows: if you see "unable to verify the first certificate", TLS is
# relaxed automatically when NODE_ENV=development. Set MONGODB_TLS_STRICT=true to enforce.
# MONGODB_TLS_INSECURE=true

# JWT Configuration (IMPORTANT: Generate strong random secrets for production)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_strong_random_secret_at_least_64_characters_long
JWT_REFRESH_SECRET=generate_another_strong_random_secret_at_least_64_characters_long

# Super Admin Configuration (for managing institutions)
SUPER_ADMIN_KEY=your_super_admin_key_here

# Email Configuration (Mailtrap)
# Sandbox (Testing) - emails captured in Mailtrap dashboard
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password

# Email API (Production) - use when ready for production
# MAILTRAP_API_TOKEN=your_mailtrap_api_token

# Server Configuration
PORT=8000
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Paystack (wallet top-ups + dedicated virtual accounts)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
# DVA bank: test-bank (dev/test), wema-bank or titan-paystack (production)
PAYSTACK_DVA_PREFERRED_BANK=test-bank
# Use demo account numbers when Paystack DVA is not enabled on your business (local testing)
PAYSTACK_DVA_MOCK=true
# Register webhook in Paystack dashboard (charge.success):
#   {BACKEND_URL}/api/payments/webhook/paystack
# Callback after card payment (set in top-up init):
#   {FRONTEND_URL}/payment/callback
# Optional: public key if needed on frontend later
# PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Environment (development, production, test)
NODE_ENV=development
