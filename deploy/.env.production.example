# Copy this to `.env` on the server (campus-id-backend/.env) and fill in real secrets.

# --- Database (MongoDB Atlas) ---
MONGODB_URL=your_atlas_mongodb_srv_connection_string
DB_NAME=campus_id_saas

# --- JWT secrets (generate strong 64+ char random values) ---
# bun -e "console.log(crypto.randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret

# --- Super admin ---
SUPER_ADMIN_KEY=your_super_admin_key

# --- Email (Resend HTTP API for real delivery) ---
# Create an API key at https://resend.com and verify your sending domain.
RESEND_API_KEY=re_your_resend_api_key
# Must be an address on your verified domain once DNS is set up.
EMAIL_FROM=Campus ID <no-reply@smartunivid.xyz>
# Optional SMTP fallback (only used if RESEND_API_KEY is unset):
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_pass

# --- Server ---
PORT=8000
NODE_ENV=production

# Public URLs — both frontends are allowed for CORS (comma-separated).
CORS_ORIGIN=https://unismart-delta.vercel.app,https://www.smartunivid.xyz,https://smartunivid.xyz
FRONTEND_URL=https://www.smartunivid.xyz
BACKEND_URL=https://api.smartunivid.xyz

# --- Paystack ---
PAYSTACK_SECRET_KEY=sk_live_or_test_key
PAYSTACK_DVA_PREFERRED_BANK=wema-bank
PAYSTACK_DVA_MOCK=false
